# ========================================
# Benchmark Profile
# ========================================

# Child-batch target endpoint for run_all.sh.
# Must be set explicitly to rag or n8n when invoking run_all.sh directly.
# BENCH_TARGET_ENDPOINT=

# Cache regime for benchmark runs
# - warm: warmup once, then run (no per-run resets) [primary]
# - cold: restart relevant services before each measured main run [secondary]
BENCH_CACHE_REGIME=warm
BENCH_COLD_RESET_WAIT=10

# Benchmark mode
# - perf: minimize overhead (no per-request rag timings, no n8n execution timings)
# - profile: collect detailed timing artifacts (rag timings, n8n timings)
BENCH_MODE=perf

# Start only required services for benchmark/audit runs (reduces noise)
BENCH_MINIMAL_STACK=1

BENCH_BOOT_WAIT=30

# Run validity policy
# - BENCH_STRICT=1: abort on any k6 check/http failure
# - BENCH_STRICT=0: keep runs and record error rates
BENCH_STRICT=0

# Run profiles
# Always source a profile before running benchmarks:
#   set -a; source bench/profiles/<profile>.env; ./bench/run_all.sh
# Available profiles:
#   - thesis_compare.env: Thesis comparison profile

# ========================================
# k6 Load Generator
# ========================================

# Arrival rate expressed per minute (RPM = requests per minute)
# With RPM=20, k6 sends 20 requests per minute, regardless of response latency
BENCH_ARRIVAL_TIME_UNIT=1m

# Open-loop arrival mode needs enough VU headroom to avoid loadgen saturation.
# Rule of thumb: required_concurrency ~= arrival_rps * latency_seconds.
BENCH_ARRIVAL_PREALLOCATED_VUS=100
BENCH_ARRIVAL_MAX_VUS=600

K6_HTTP_TIMEOUT=120s
K6_REQUIRE_CITATIONS=0

# ========================================
# Sweep Thresholds
# ========================================

BENCH_SWEEP_TIMEOUT_RATE_MAX=0.01

# If 1: require prompt-tagged counters for prompt-mix validity checks.
BENCH_SWEEP_REQUIRE_PROMPT_TAGS=0

# ========================================
# Prompt Configuration
# ========================================

# Benchmark prompt set is selected by the sourced profile.
# If unset, the runner falls back to /bench/prompts.json.
# BENCH_PROMPTS_PATH=

# Prompt set used by boundary audit (uses 15 prompts from prompts.json)
BOUNDARY_AUDIT_PROMPTS_PATH=/bench/prompts.json

# Seed for reproducible per-repetition prompt ordering
PROMPT_BASE_SEED=20260318

# ========================================
# LLM Parameters (Shared)
# ========================================

# Locked LLM sampling / output params (system comparison, not model comparison)
# Keep these identical across n8n and rag_service.
LLM_TEMPERATURE=1
LLM_TOP_P=1
LLM_MAX_COMPLETION_TOKENS=32768

# ========================================
# n8n Configuration
# ========================================

# n8n worker scaling
BENCH_N8N_WORKERS=5

# Whether to restart n8n-worker too during cold resets (1=yes, 0=no)
BENCH_COLD_RESET_N8N_WORKERS=1

# n8n endpoints
N8N_WEBHOOK_URL=http://n8n:5678/webhook/call_openwebui
# Optional: set explicitly to avoid ambiguous webhook-path matches when snapshotting.
N8N_WORKFLOW_ID=Q6X7JeDOqCT3Nu7M

# n8n auth headers (optional)
N8N_AUTH_HEADER=
N8N_AUTH_VALUE=

# Primary n8n OpenAI credential used for normal benchmark runs.
# Boundary audits temporarily switch the workflow away from this credential,
# then restore it before the real benchmark run.
N8N_OPENAI_CREDENTIAL_NAME="OpenAi account"
N8N_OPENAI_CREDENTIAL_ID=phZdcQrYW2peVPgf
N8N_CHAT_MODEL=gpt-5-nano
N8N_EMBEDDING_MODEL=text-embedding-3-small
N8N_OPENAI_BASE_URL=

# Dedicated OpenAI credential used only during boundary audits.
# It must point to http://openai-proxy-n8n:8081/v1 so the harness can observe
# actual upstream model calls, parameters, and token usage through the proxy.
N8N_AUDIT_OPENAI_CREDENTIAL_NAME="OpenAi audit proxy"
N8N_AUDIT_OPENAI_CREDENTIAL_ID=TzCIUUyDbp29AN5s

# n8n database
N8N_DB_NAME=n8n_data

# ========================================
# RAG Service Configuration
# ========================================

# rag_service benchmark scaling (5 processing workers, concurrency=1 each)
RAG_WORKER_COUNT=5

# API worker processes to avoid front-end bottleneck with blocking polling
RAG_API_WORKERS=8

# Disable in-process API rate limiting during benchmarks.
# Otherwise the limiter can become the dominant bottleneck in open-loop sweeps.
RATE_LIMIT_ENABLED=false

# rag_service cache policy (make defaults explicit for thesis-grade reproducibility)
EMBEDDING_CACHE_ENABLED=true
VECTOR_SEARCH_CACHE_ENABLED=true
SEMANTIC_LLM_CACHE_ENABLED=true
LLM_CACHE_ENABLED=true

# RAG endpoint
RAG_ENDPOINT_URL=http://rag-pipeline:8080/query

# RAG auth token (optional)
RAG_API_TOKEN=

# Measurement-mode instrumentation (keep overhead minimal and symmetric)
RAG_TIMINGS_ON_ERROR_ONLY=false
LOG_OPENAI_USAGE=true

# ========================================
# Thesis Inputs (set by profile / per run)
# ========================================

# Thesis-grade prereg/pair enforcement is configured by the sourced profile.
# For thesis runs, set BENCH_BOUNDARY_AUDIT_REPORT_PATH to a fresh
# boundary_audit_report.json before invoking ./bench/run_compare_pair.sh.
# BENCH_BOUNDARY_AUDIT_REPORT_PATH=

# ========================================
# Boundary Audit Settings
# ========================================

# Boundary audit (not a performance benchmark)
# Verifies both systems use the same models and parameters
BOUNDARY_AUDIT_PROMPT_COUNT=20
BOUNDARY_AUDIT_HTTP_TIMEOUT=120
BOUNDARY_AUDIT_SLEEP_MS=200
BOUNDARY_AUDIT_STRICT=1
BOUNDARY_AUDIT_REQUIRE_ALL_USER_REQUESTS_OK=1
BOUNDARY_AUDIT_MIN_PROXY_OK_RATE=0.99

# ========================================
# Infrastructure / Exporters
# ========================================

# Monitoring ports
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003
JAEGER_PORT=16686
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=benchadmin

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
REDIS_EXPORTER_ADDR=redis://redis:6379

# Tracing
OTEL_TRACES_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLER_ARG=0.2

# OpenAI proxy (audit runs only)
UPSTREAM_OPENAI_BASE_URL=https://api.openai.com
PROXY_TIMEOUT_SECONDS=180
