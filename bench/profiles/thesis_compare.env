# Thesis-grade isolated comparison benchmark.
#
# Prerequisites:
#   1. Run endpoint smoke validation for both endpoints
#      (override BENCH_REQUIRE_BOUNDARY_AUDIT=0 and set BENCH_SWEEP_SMOKE_RPM_LIST)
#   2. Verify smoke passes
#   3. Ensure services remain running (no restart)
#
# Usage:
#   set -a; source bench/profiles/thesis_compare.env
#   ./bench/run_boundary_audit.sh
#   export BENCH_BOUNDARY_AUDIT_REPORT_PATH=/absolute/path/to/boundary_audit_report.json
#   ./bench/run_compare_pair.sh
#
# This is the canonical final thesis profile.
# General runtime defaults live in bench/.env; this file only sets
# thesis-specific benchmark, prompt, and enforcement settings.

# Smoke test (validation for primary run)
BENCH_SWEEP_STOP_AFTER_SMOKE=0
# Smoke parameters
BENCH_SWEEP_SMOKE_RPM_LIST=
BENCH_SWEEP_SMOKE_SETTLE_SECONDS=10
BENCH_SWEEP_SMOKE_MEASURE_SECONDS=120
BENCH_SWEEP_SMOKE_REPS=1

# Primary sweep parameters
BENCH_SWEEP_PRIMARY_RPM_START=10
BENCH_SWEEP_PRIMARY_RPM_END=100
BENCH_SWEEP_PRIMARY_RPM_STEP=10
BENCH_SWEEP_PRIMARY_SETTLE_SECONDS=180
BENCH_SWEEP_PRIMARY_MEASURE_SECONDS=720
# Reps for each point in a child batch (state of the benchmark is shared between reps)
# Is not used, since state isolation is needed for n8n (cleared state for queued requests)
# BENCH_PAIR_REPS is set to 3 for multiple child batches
BENCH_SWEEP_PRIMARY_REPS=

# Pair comparison settings
# Reps for each child batch in one run (state of the benchmark is not shared between reps)
BENCH_PAIR_REPS=3
BENCH_PAIR_ORDER_MODE=alternate_by_rep

# Final thesis prompt set
BENCH_PROMPTS_PATH=/bench/prompts.json

# Final thesis-grade enforcement

# Preregistration decision evaluation (best-effort)
# can be set to 0 on smoke benchmark tests
BENCH_PREREG_EVAL=1

# If 1: fail the batch when thesis validity fails
# (e.g. prereg mismatch, failed pair validation, missing required analysis,
# or no shared valid comparison points)
BENCH_PREREG_ENFORCE=1

# Boundary audit requirement
# - Require an attached validity-mode boundary audit report with pass=true
BENCH_REQUIRE_BOUNDARY_AUDIT=1

# Validate required thesis artifacts at end of run_all.sh
BENCH_VALIDATE_BATCH_STRICT=1

# Boundary audit attachment is required for thesis runs.
# Set BENCH_BOUNDARY_AUDIT_REPORT_PATH to a fresh boundary_audit_report.json
# before running ./bench/run_compare_pair.sh.

# Enable token usage logging for correlation analysis
LOG_OPENAI_USAGE=true
